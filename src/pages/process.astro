---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Aurora from '../components/Aurora.astro';
import PageHero from '../components/PageHero.astro';
import Process from '../components/Process.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { processFaqs } from '../data/process';
---

<Layout
  title="Process - SUE Agency"
  description="Four weeks from kickoff to launch. Discover, design, build, ship: the way we run every project."
>
  <Nav activeLink="Process" />
  <main class="relative pt-18.25">
    <Aurora variant="compact" />

    <PageHero
      eyebrow="How we work"
      title="Four weeks to launch."
      titleAccent="Four weeks"
      description="A tight, transparent process. Discover, design, build, ship, with a working preview URL from week two and a live site by week four."
    />

    <Process showHeader={false} />

    <section class="relative z-10 mx-auto max-w-310 px-8 pt-20 pb-6" data-reveal-stagger>
      <div class="text-accent mb-4 text-[13px] font-semibold tracking-[0.14em] uppercase">
        Frequently asked
      </div>
      <h2
        class="font-display m-0 mb-10 text-[clamp(28px,3.6vw,42px)] leading-none font-bold tracking-[-0.03em]"
      >
        Before we start.
      </h2>
      <div class="divide-dark/10 border-dark/10 divide-y border-y">
        {
          processFaqs.map((faq) => (
            <div class="py-7">
              <h3 class="font-display m-0 mb-3 text-[19px] font-bold tracking-[-0.02em]">
                {faq.q}
              </h3>
              <p class="text-muted m-0 max-w-[60ch] text-base leading-[1.6]">{faq.a}</p>
            </div>
          ))
        }
      </div>
    </section>

    <div class="offscreen">
      <CTA />
    </div>
  </main>
  <div class="offscreen">
    <Footer />
  </div>
</Layout>
