---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Aurora from '../components/Aurora.astro';
import PageHero from '../components/PageHero.astro';
import Services from '../components/Services.astro';
import ServiceCatalog from '../components/ServiceCatalog.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { servicesIncludes } from '../data/services';
---

<Layout
  title="Services - SUE Agency"
  description="Design, engineering, headless CMS, and performance. Full-stack web from one studio."
>
  <Nav activeLink="Services" />
  <main class="relative pt-18.25">
    <Aurora variant="compact" />

    <PageHero
      eyebrow="What we do"
      title="Full-stack web, minus the bloat."
      titleAccent="Full-stack"
      description="Design, engineering, and content: one team, one bill, one launch. From first pixel to production, we own the whole pipeline."
    />

    <Services showHeader={false} />

    <ServiceCatalog />

    <section class="relative z-10 mx-auto max-w-310 px-8 pt-16 pb-6">
      <div class="border-dark/10 bg-card rounded-[22px] border p-10" data-reveal>
        <div class="text-accent mb-4 text-[13px] font-semibold tracking-[0.14em] uppercase">
          Every project also includes
        </div>
        <ul class="grid gap-3 md:grid-cols-2">
          {
            servicesIncludes.map((item) => (
              <li class="text-dark flex items-start gap-3 text-base">
                <span class="bg-accent mt-2 h-1.5 w-1.5 shrink-0 rounded-full" aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <div class="offscreen">
      <CTA />
    </div>
  </main>
  <div class="offscreen">
    <Footer />
  </div>
</Layout>
