---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Aurora from '../components/Aurora.astro';
import PageHero from '../components/PageHero.astro';
import Services from '../components/Services.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const includes = [
  'A design system documented in code — your team can extend it',
  'Automated Lighthouse checks on every pull request',
  'WCAG 2.2 AA accessibility audit before launch',
  'Analytics + Core Web Vitals monitoring wired up on day one',
  'A handoff runbook so maintainers know exactly what we built',
];
---

<Layout
  title="Services — SUE Agency"
  description="Design, engineering, headless CMS, and performance — full-stack web from one studio."
>
  <Nav activeLink="Services" />
  <main class="relative pt-18.25">
    <Aurora variant="compact" />

    <PageHero
      eyebrow="What we do"
      title="Full-stack web, minus the bloat."
      titleAccent="Full-stack"
      description="Design, engineering, and content — one team, one bill, one launch. From first pixel to production, we own the whole pipeline."
    />

    <Services showHeader={false} />

    <section class="relative z-10 mx-auto max-w-310 px-8 pt-16 pb-6">
      <div class="rounded-[22px] border border-dark/10 bg-card p-10">
        <div
          class="mb-4 text-[13px] font-semibold uppercase tracking-[0.14em] text-accent"
        >
          Every project also includes
        </div>
        <ul class="grid gap-3 md:grid-cols-2">
          {includes.map((item) => (
            <li class="flex items-start gap-3 text-base text-dark">
              <span
                class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"
                aria-hidden="true"
              ></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <div class="offscreen">
      <CTA />
    </div>
  </main>
  <div class="offscreen">
    <Footer />
  </div>
</Layout>
