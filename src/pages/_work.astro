---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Aurora from '../components/Aurora.astro';
import PageHero from '../components/PageHero.astro';
import CaseCard from '../components/CaseCard.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { getAllCases } from '../data/cases';

const list = getAllCases();
---

<Layout
  title="Work - SUE Agency"
  description="Selected case studies from the SUE studio. Sites shipped fast, on the edge, with Lighthouse 100."
>
  <Nav activeLink="Work" />
  <main class="relative pt-18.25">
    <Aurora variant="compact" />

    <PageHero
      eyebrow="Selected work"
      title="Every project we've shipped."
      titleAccent="shipped"
      description="A cross-section of the sites we've built: DTC storefronts, editorial platforms, SaaS dashboards, and B2B marketing. All shipped fast, on the edge, at Lighthouse 100."
    />

    <section class="relative z-10 mx-auto max-w-310 px-8 pt-6 pb-10">
      <div class="grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-5.5" data-reveal-stagger>
        {list.map((c) => <CaseCard post={c} />)}
      </div>
    </section>

    <div class="offscreen">
      <CTA />
    </div>
  </main>
  <div class="offscreen">
    <Footer />
  </div>
</Layout>
