---
import Eyebrow from './ui/Eyebrow.astro';
import { services } from '../data/services';

interface Props {
  showHeader?: boolean;
}
const { showHeader = true } = Astro.props;
---

<section id="services" class="relative z-10 mx-auto max-w-310 px-8 pt-24 pb-6">
  {
    showHeader && (
      <div class="mb-11.5 flex flex-wrap items-end justify-between gap-6" data-reveal>
        <div>
          <Eyebrow class="mb-4">What we do</Eyebrow>
          <h2 class="font-display m-0 max-w-[14ch] text-[clamp(32px,4.6vw,60px)] leading-none font-bold tracking-[-0.03em]">
            Full-stack web, minus the bloat.
          </h2>
        </div>
        <p class="text-muted m-0 mb-1.5 max-w-[34ch] text-base">
          From first pixel to production, we own the whole pipeline, so nothing gets lost between
          design and deploy.
        </p>
      </div>
    )
  }

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
    {
      services.map((s) => (
        <article class="border-dark/10 bg-card hover:border-dark/15 flex min-h-65 flex-col gap-4 rounded-[18px] border p-7.5 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-[0_26px_50px_-30px_rgba(26,22,17,0.32)]">
          <div class="font-display text-accent text-[15px] font-bold">{s.num}</div>
          <h3 class="font-display m-0 text-2xl font-bold tracking-[-0.02em]">{s.title}</h3>
          <p class="text-muted m-0 text-[15px] leading-[1.55]">{s.body}</p>
          {Array.isArray(s.meta) ? (
            <div class="text-subtle mt-auto flex flex-col gap-1 text-sm">
              {s.meta.map((line) => (
                <div>{line}</div>
              ))}
            </div>
          ) : (
            <div class="text-subtle mt-auto text-sm">{s.meta}</div>
          )}
        </article>
      ))
    }
  </div>
</section>
