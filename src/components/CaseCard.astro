---
import type { CaseStudy } from '../data/cases';
import Tag from './ui/Tag.astro';

interface Props {
  post: CaseStudy;
}
const { post } = Astro.props;
---

<div class="group block text-inherit no-underline">
  <div
    class="border-dark/10 relative aspect-4/3 overflow-hidden rounded-[20px] border shadow-[0_6px_20px_-12px_rgba(26,22,17,0.25)] transition-all duration-300 ease-out group-hover:-translate-y-1.5 group-hover:shadow-[0_34px_60px_-30px_rgba(26,22,17,0.42)]"
    style={`background: ${post.gradient};`}
  >
    <div
      class="bg-ink absolute inset-6 flex flex-col gap-2.5 rounded-[14px] p-4"
      aria-hidden="true"
    >
      {
        post.mockup === 'form' && (
          <>
            <div class="flex gap-1.5">
              <span class="bg-accent h-2.25 w-2.25 rounded-full" />
              <span class="bg-amber-brand h-2.25 w-2.25 rounded-full" />
              <span class="bg-emerald-brand h-2.25 w-2.25 rounded-full" />
            </div>
            <div class="bg-cream/90 mt-1.5 h-3.5 w-3/5 rounded" />
            <div class="bg-cream/35 h-2.25 w-[85%] rounded" />
            <div class="bg-cream/35 h-2.25 w-[72%] rounded" />
            <div class="mt-auto h-7.5 w-30 rounded-lg" style={`background: ${post.accent};`} />
          </>
        )
      }
      {
        post.mockup === 'dashboard' && (
          <>
            <div class="flex items-center gap-2">
              <div class="h-6 w-6 rounded-md" style={`background: ${post.accent};`} />
              <div class="bg-cream/80 h-2.5 w-20 rounded" />
            </div>
            <div class="mt-2 flex gap-2">
              <div class="bg-cream/15 h-11.5 flex-1 rounded-lg" />
              <div class="bg-cream/15 h-11.5 flex-1 rounded-lg" />
            </div>
            <div class="bg-cream/35 mt-1 h-2.25 w-[90%] rounded" />
            <div class="bg-cream/35 h-2.25 w-[65%] rounded" />
          </>
        )
      }
      {
        post.mockup === 'editorial' && (
          <>
            <div class="bg-cream/90 h-4 w-1/2 rounded" />
            <div class="bg-cream/30 h-2.25 w-4/5 rounded" />
            <div class="mt-auto flex gap-2">
              <div class="h-8.5 w-8.5 rounded-full" style={`background: ${post.accent};`} />
              <div class="bg-cream/20 h-8.5 w-8.5 rounded-full" />
              <div class="bg-cream/20 h-8.5 w-8.5 rounded-full" />
            </div>
          </>
        )
      }
    </div>
  </div>
  <div class="px-1 pt-5">
    <div class="mb-3 flex gap-2">
      <Tag>{post.category}</Tag>
      <Tag>{post.stack}</Tag>
    </div>
    <h3 class="title-fill font-display m-0 mb-1.5 text-2xl font-bold tracking-[-0.02em]">
      {post.client}, {post.subtitle}
    </h3>
    <p class="text-muted m-0 text-[15px]">{post.excerpt}</p>
  </div>
</div>
