---
import Eyebrow from './ui/Eyebrow.astro';
import { serviceCatalog } from '../data/services';
---

<section class="relative z-10 mx-auto max-w-310 px-8 pt-20 pb-6">
  <div class="mb-11.5 max-w-[46ch]" data-reveal>
    <Eyebrow class="mb-4">In detail</Eyebrow>
    <h2
      class="font-display m-0 text-[clamp(32px,4.6vw,60px)] leading-none font-bold tracking-[-0.03em]"
    >
      Every engagement, unpacked.
    </h2>
    <p class="text-muted mt-5 text-base">
      A closer look at what we ship inside each phase. Pick the pieces your team needs, mix them, or
      take the whole four-week sprint.
    </p>
  </div>

  <div class="flex flex-col gap-16">
    {
      serviceCatalog.map((group) => (
        <div data-reveal>
          <div class="border-dark/10 mb-6 flex items-baseline justify-between gap-4 border-b pb-4">
            <h3 class="font-display text-dark m-0 text-[clamp(20px,2.4vw,26px)] font-bold tracking-[-0.02em]">
              {group.label}
            </h3>
            <span class="text-subtle text-[13px] tracking-[0.14em] uppercase">
              {group.items.length} service{group.items.length === 1 ? '' : 's'}
            </span>
          </div>
          <div class="columns-1 gap-4 md:columns-2">
            {group.items.map((item) => (
              <details class="group border-dark/10 bg-card open:border-dark/20 hover:border-dark/20 mb-4 block break-inside-avoid rounded-[18px] border p-6 transition-colors">
                <summary class="flex cursor-pointer list-none items-start gap-4 [&::-webkit-details-marker]:hidden">
                  <span
                    class="font-display border-dark/15 text-accent flex h-9 w-9 shrink-0 items-center justify-center rounded-full border text-sm font-bold"
                    aria-hidden="true"
                  >
                    {item.letter}
                  </span>
                  <div class="min-w-0 flex-1">
                    <div class="font-display text-dark text-lg font-bold tracking-[-0.01em]">
                      {item.title}
                    </div>
                    <p class="text-muted m-0 mt-1.5 text-[15px] leading-normal">{item.question}</p>
                  </div>
                  <span
                    class="text-subtle mt-1.5 shrink-0 text-lg leading-none transition-transform group-open:rotate-45"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <p class="text-muted m-0 mt-5 pl-13 text-[15px] leading-[1.6]">{item.body}</p>
              </details>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
