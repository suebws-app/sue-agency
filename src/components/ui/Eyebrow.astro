---
interface Props {
  onDark?: boolean;
  class?: string;
}
const { onDark = false, class: className = '' } = Astro.props;
---

<div
  class:list={[
    'text-[13px] font-semibold uppercase tracking-[0.14em]',
    onDark ? 'text-accent-vivid' : 'text-accent',
    className,
  ]}
>
  <slot />
</div>
