---
interface Props {
  size?: number;
  class?: string;
}
const { size = 40, class: className = '' } = Astro.props;
---

<span
  class:list={['shrink-0 inline-block rounded-full', className]}
  style={`width: ${size}px; height: ${size}px; background: linear-gradient(135deg, #FF5233, #7C5CFF);`}
  aria-hidden="true"
></span>
