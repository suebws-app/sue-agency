---
interface Props {
  href: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}
const { href, size = 'sm', class: className = '' } = Astro.props;

const sizeClass = {
  sm: 'px-5 py-2.75 text-sm',
  md: 'px-5.5 py-3.25 text-sm',
  lg: 'px-7.5 py-4 text-base',
}[size];
---

<a
  href={href}
  class:list={[
    'bg-dark text-cream hover:bg-accent rounded-full font-semibold whitespace-nowrap no-underline shadow-[0_10px_24px_-14px_rgba(20,18,16,0.45)] hover:-translate-y-0.5 hover:shadow-[0_18px_36px_-16px_rgba(208,48,26,0.5)] active:translate-y-0 active:shadow-[0_8px_20px_-14px_rgba(20,18,16,0.45)]',
    sizeClass,
    className,
  ]}
>
  <slot />
</a>
