---
interface Props {
  words: string[];
}

const { words } = Astro.props;
const longest = words.reduce((a, b) => (a.length >= b.length ? a : b), '');
const durationPerWord = 3; // seconds per word
const total = words.length * durationPerWord;
---

<span
  class="text-accent relative inline-block align-top font-serif font-normal tracking-[-0.01em] italic"
>
  <span class="invisible whitespace-nowrap">{longest}</span>
  {
    words.map((word, i) => (
      <span
        class="pointer-events-none absolute top-0 left-0 [animation:vl-word_var(--total)_cubic-bezier(0.4,0,0.2,1)_infinite] whitespace-nowrap opacity-0"
        style={`--total: ${total}s; animation-delay: ${i * durationPerWord}s;`}
        aria-hidden={i !== 0}
      >
        {word}
      </span>
    ))
  }
</span>
