---
import RotatingWord from './RotatingWord.astro';
import { heroRotatingWords } from '../data/site';
---

<section class="relative z-10 mx-auto max-w-310 px-8 pt-19.5 pb-16" data-reveal-stagger>
  <h1
    class="font-display m-0 max-w-[16ch] text-[clamp(46px,8.2vw,116px)] leading-[0.98] font-bold tracking-[-0.035em]"
  >
    Fast websites for brands that{' '}
    <RotatingWord words={heroRotatingWords} />
  </h1>
  <div class="mt-10 flex flex-wrap items-end justify-between gap-8">
    <p class="text-muted m-0 max-w-[46ch] text-[19px] leading-normal">
      SUE is a web studio crafting high-performance, composable sites. Engineered for speed,
      designed to convert, and built to scale.
    </p>
    <div class="flex flex-wrap gap-3">
      <a
        href="/contact"
        class="bg-accent rounded-full px-6.5 py-3.75 text-[15px] font-semibold whitespace-nowrap text-white no-underline shadow-[0_14px_30px_-12px_rgba(26,22,17,0.4)] transition-all duration-300 ease-out hover:-translate-y-0.5 hover:shadow-[0_20px_40px_-14px_rgba(26,22,17,0.5)] hover:brightness-95"
      >
        Start a project
      </a>
    </div>
  </div>
</section>
