---
import Logo from './Logo.astro';
import { footerColumns } from '../data/navigation';
---

<footer class="border-dark/15 relative z-10 border-t">
  <div class="mx-auto flex max-w-310 flex-wrap justify-between gap-10 px-8 pt-14 pb-10">
    <div class="max-w-70">
      <div class="mb-4">
        <Logo href="/" />
      </div>
      <p class="text-subtle m-0 text-sm leading-[1.55]">
        A web studio building fast, composable sites for ambitious brands.
      </p>
    </div>
    <div class="flex flex-wrap gap-14">
      {
        footerColumns.map((col) => (
          <div class="flex flex-col gap-3">
            <div class="text-subtle mb-0.5 text-xs tracking-[0.12em] uppercase">{col.label}</div>
            {col.links.map((link) => (
              <a href={link.href} class="text-dark hover:text-accent text-[15px] no-underline">
                {link.label}
              </a>
            ))}
          </div>
        ))
      }
    </div>
  </div>
  <div
    class="text-subtle mx-auto flex max-w-310 flex-wrap justify-between gap-4 px-8 pb-10 text-[13px]"
  >
    <span>© 2026 SUE Agency. All rights reserved.</span>
    <span>Made fast, on the edge.</span>
  </div>
</footer>
