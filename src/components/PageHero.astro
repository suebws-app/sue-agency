---
import { cn } from '../lib/cn';
import Eyebrow from './ui/Eyebrow.astro';

interface Props {
  eyebrow: string;
  title: string;
  titleAccent?: string;
  description: string;
  eyebrowClassName?: string;
}

const { eyebrow, title, titleAccent, description, eyebrowClassName } = Astro.props;

let before = title;
let after = '';
if (titleAccent && title.includes(titleAccent)) {
  const idx = title.indexOf(titleAccent);
  before = title.slice(0, idx).trimEnd();
  after = title.slice(idx + titleAccent.length).trimStart();
}
---

<section class="relative z-10 mx-auto max-w-310 px-8 pt-20 pb-10" data-reveal-stagger>
  <Eyebrow class={cn('mb-4.5', eyebrowClassName)}>{eyebrow}</Eyebrow>
  <h1
    class="font-display m-0 max-w-[16ch] text-[clamp(44px,7vw,96px)] leading-[0.98] font-bold tracking-[-0.035em]"
  >
    {
      titleAccent ? (
        <>
          {before}
          {before && ' '}
          <span class="text-accent font-serif font-normal italic">{titleAccent}</span>
          {after && ' '}
          {after}
        </>
      ) : (
        title
      )
    }
  </h1>
  <p class="text-muted mt-7 max-w-[52ch] text-[19px] leading-normal">
    {description}
  </p>
</section>
