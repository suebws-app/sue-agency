---
import CaseCard from './CaseCard.astro';
import Eyebrow from './ui/Eyebrow.astro';
import TextLink from './ui/TextLink.astro';
import { getFeaturedCases } from '../data/cases';

const list = getFeaturedCases(3);
---

<section id="work" class="relative z-10 mx-auto max-w-310 px-8 pt-6 pb-10">
  <div class="mb-10 flex flex-wrap items-end justify-between gap-6">
    <div>
      <Eyebrow class="mb-4">Selected work</Eyebrow>
      <h2
        class="font-display m-0 text-[clamp(32px,4.6vw,60px)] font-bold leading-none tracking-[-0.03em]"
      >
        Recent launches.
      </h2>
    </div>
    <TextLink href="/work">View all case studies →</TextLink>
  </div>

  <div class="grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-5.5">
    {list.map((c) => <CaseCard post={c} />)}
  </div>
</section>
