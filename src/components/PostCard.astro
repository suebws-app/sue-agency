---
import type { Post } from '../data/posts';
import Tag from './ui/Tag.astro';

interface Props {
  post: Post;
}
const { post } = Astro.props;
---

<a
  href={`/journal/${post.slug}`}
  class="border-dark/10 bg-card flex flex-col overflow-hidden rounded-[20px] border no-underline transition-all duration-300 ease-out hover:-translate-y-1.5 hover:shadow-[0_30px_54px_-32px_rgba(26,22,17,0.4)]"
>
  <div class="relative aspect-16/10 overflow-hidden" style={`background: ${post.bg};`}>
    <div class="bg-ink absolute inset-5 flex flex-col gap-2.25 rounded-xl p-4" aria-hidden="true">
      <div class="bg-bg/90 h-3 w-[62%] rounded"></div>
      <div class="bg-bg/30 h-2 w-[88%] rounded"></div>
      <div class="bg-bg/30 h-2 w-[74%] rounded"></div>
      <div class="mt-auto h-6 w-24 rounded-md" style={`background: ${post.accent};`}></div>
    </div>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-3.5 flex gap-2">
      <Tag>{post.tag}</Tag>
    </div>
    <h3
      class="font-display text-dark m-0 mb-2.5 text-[21px] leading-[1.12] font-bold tracking-[-0.02em]"
    >
      {post.title}
    </h3>
    <p class="text-muted m-0 mb-5 text-[15px] leading-[1.55]">{post.excerpt}</p>
    <div class="text-subtle mt-auto flex items-center gap-2.5 text-[13px]">
      <span>{post.date}</span>
      <span aria-hidden="true">·</span>
      <span>{post.read}</span>
    </div>
  </div>
</a>
