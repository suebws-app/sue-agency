---
import type { Post } from '../data/posts';
import Tag from './ui/Tag.astro';

interface Props {
  post: Post;
}
const { post } = Astro.props;
---

<a
  href={`/journal/${post.slug}`}
  class="transition-all duration-300 ease-out flex flex-col overflow-hidden rounded-[20px] border border-dark/10 bg-card no-underline hover:-translate-y-1.5 hover:shadow-[0_30px_54px_-32px_rgba(26,22,17,0.4)]"
>
  <div
    class="relative aspect-16/10 overflow-hidden"
    style={`background: ${post.bg};`}
  >
    <div
      class="absolute inset-5 flex flex-col gap-2.25 rounded-xl bg-ink p-4"
      aria-hidden="true"
    >
      <div class="h-3 w-[62%] rounded bg-bg/90"></div>
      <div class="h-2 w-[88%] rounded bg-bg/30"></div>
      <div class="h-2 w-[74%] rounded bg-bg/30"></div>
      <div
        class="mt-auto h-6 w-24 rounded-md"
        style={`background: ${post.accent};`}
      ></div>
    </div>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-3.5 flex gap-2">
      <Tag>{post.tag}</Tag>
    </div>
    <h3
      class="font-display m-0 mb-2.5 text-[21px] font-bold leading-[1.12] tracking-[-0.02em] text-dark"
    >
      {post.title}
    </h3>
    <p class="m-0 mb-5 text-[15px] leading-[1.55] text-muted">{post.excerpt}</p>
    <div class="mt-auto flex items-center gap-2.5 text-[13px] text-subtle">
      <span>{post.date}</span>
      <span aria-hidden="true">·</span>
      <span>{post.read}</span>
    </div>
  </div>
</a>
