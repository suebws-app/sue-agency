---
interface Props {
  href?: string;
}
const { href = '#' } = Astro.props;
---

<a
  href={href}
  class="inline-flex items-center gap-2.25 text-dark no-underline"
  aria-label="SUE Agency home"
>
  <span class="font-display text-[23px] font-extrabold tracking-[-0.03em]">SUE</span>
  <span
    class="mt-1.5 inline-block h-2.25 w-2.25 rounded-full bg-accent"
    aria-hidden="true"
  ></span>
</a>
