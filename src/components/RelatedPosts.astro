---
import type { Post } from '../data/posts';
import Tag from './ui/Tag.astro';
import TextLink from './ui/TextLink.astro';

interface Props {
  posts: Post[];
}
const { posts } = Astro.props;
---

<section class="relative z-10 mx-auto max-w-310 px-8 pt-14 pb-10">
  <div class="mb-8 flex flex-wrap items-end justify-between gap-6" data-reveal>
    <h2
      class="font-display m-0 text-[clamp(26px,3.4vw,40px)] leading-none font-bold tracking-[-0.03em]"
    >
      Keep reading
    </h2>
    <TextLink href="/journal">All articles →</TextLink>
  </div>

  <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-5.5" data-reveal-stagger>
    {
      posts.map((post) => (
        <a
          href={`/journal/${post.slug}`}
          class="border-dark/10 bg-card flex flex-col overflow-hidden rounded-[20px] border no-underline transition-all duration-300 ease-out hover:-translate-y-1.5 hover:shadow-[0_30px_54px_-32px_rgba(26,22,17,0.4)]"
        >
          <div class="aspect-16/10" style={`background: ${post.bg};`} aria-hidden="true" />
          <div class="p-5.5">
            <Tag class="mb-3 inline-block">{post.tag}</Tag>
            <h3 class="font-display text-dark m-0 mb-2 text-[19px] leading-[1.14] font-bold tracking-[-0.02em]">
              {post.title}
            </h3>
            <div class="text-subtle text-[13px]">
              {post.date} · {post.read}
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>
