---
import { categories } from '../data/posts';

interface Props {
  active?: string;
}
const { active = 'All' } = Astro.props;
---

<section
  class="relative z-10 mx-auto max-w-310 px-8 pb-9 pt-2"
  data-category-filter
>
  <div class="flex flex-wrap gap-2.5">
    {categories.map((cat) => (
      <button
        type="button"
        data-category={cat}
        data-active={cat === active ? 'true' : 'false'}
        class="rounded-full border px-4.5 py-2.25 text-sm transition-colors data-[active=true]:border-transparent data-[active=true]:bg-dark data-[active=true]:font-semibold data-[active=true]:text-bg data-[active=false]:border-dark/15 data-[active=false]:text-muted data-[active=false]:hover:border-dark"
      >
        {cat}
      </button>
    ))}
  </div>
  <p
    data-empty-state
    hidden
    class="mt-6 text-sm text-subtle"
  >
    No posts in this category yet.
  </p>
</section>

<script>
  const filter = document.querySelector<HTMLElement>('[data-category-filter]');
  if (filter) {
    const buttons = filter.querySelectorAll<HTMLButtonElement>('[data-category]');
    const emptyState = filter.querySelector<HTMLElement>('[data-empty-state]');
    const cards = document.querySelectorAll<HTMLElement>('[data-post-tag]');
    const hero = document.querySelector<HTMLElement>('[data-featured-hero]');

    const applyFilter = (category: string) => {
      const isAll = category === 'All';
      if (hero) hero.toggleAttribute('hidden', !isAll);

      let visible = 0;
      cards.forEach((el) => {
        const tagMatch = isAll || el.dataset.postTag === category;
        const skipFeaturedInAll = isAll && el.dataset.featured === 'true';
        const show = tagMatch && !skipFeaturedInAll;
        el.toggleAttribute('hidden', !show);
        if (show) visible += 1;
      });

      const heroVisible = isAll && hero !== null;
      if (emptyState)
        emptyState.toggleAttribute('hidden', visible > 0 || heroVisible);
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const category = btn.dataset.category ?? 'All';
        buttons.forEach((b) =>
          b.setAttribute('data-active', b === btn ? 'true' : 'false'),
        );
        applyFilter(category);
      });
    });

    applyFilter('All');
  }
</script>
