---
import { homepageStats } from '../data/site';
---

<section class="relative z-10 mx-auto max-w-310 px-8 py-18">
  <div
    class="border-dark/15 grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] gap-6 border-y py-12"
    data-reveal-stagger
  >
    {
      homepageStats.map((s) => (
        <div class="text-center">
          <div class="font-display text-[clamp(44px,5.5vw,72px)] leading-[0.9] font-bold tracking-[-0.04em]">
            {s.value}
            {s.suffix && <span class="text-accent text-[0.42em]">{s.suffix}</span>}
          </div>
          <div class="text-muted mt-2.5 text-[15px]">{s.label}</div>
        </div>
      ))
    }
  </div>
</section>
