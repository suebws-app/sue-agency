---
import { getFeaturedPost } from '../data/posts';
import AuroraGlow from './ui/AuroraGlow.astro';
import GradientAvatar from './ui/GradientAvatar.astro';
import StatItem from './ui/StatItem.astro';
import Tag from './ui/Tag.astro';

const featured = getFeaturedPost();
const stats = featured.heroStats ?? [];
---

<section
  class="relative z-10 mx-auto max-w-310 px-8 pb-5"
  data-featured-hero
>
  <a
    href={`/journal/${featured.slug}`}
    class="group grid grid-cols-1 gap-0 overflow-hidden rounded-[22px] transition-all duration-300 ease-out border border-dark/10 bg-card no-underline lg:grid-cols-[1.1fr_1fr] hover:-translate-y-1 hover:shadow-[0_34px_60px_-34px_rgba(26,22,17,0.4)]"
  >
    <div class="relative min-h-85 overflow-hidden bg-ink">
      <AuroraGlow />
      <div class="absolute inset-x-8 bottom-8 flex gap-6.5 text-bg">
        {stats.map((stat) => (
          <StatItem value={stat.value} label={stat.label} size="md" />
        ))}
      </div>
    </div>

    <div class="flex flex-col justify-center p-10 text-dark">
      <div class="mb-4 flex items-center gap-2">
        <Tag variant="accent">Featured</Tag>
        <Tag>{featured.tag}</Tag>
      </div>
      <h2
        class="font-display m-0 mb-3.5 text-[clamp(26px,3vw,38px)] font-bold leading-[1.04] tracking-tight"
      >
        {featured.title}
      </h2>
      <p class="m-0 mb-6 text-base leading-[1.6] text-muted">
        {featured.excerpt}
      </p>
      <div class="flex items-center gap-3 text-sm text-subtle">
        <GradientAvatar size={34} />
        <span class="font-semibold text-dark">{featured.author.name}</span>
        <span aria-hidden="true">·</span>
        <span>{featured.date}</span>
        <span aria-hidden="true">·</span>
        <span>{featured.read}</span>
      </div>
    </div>
  </a>
</section>
