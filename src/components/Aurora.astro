---
interface Props {
  variant?: 'hero' | 'compact' | 'minimal';
}
const { variant = 'hero' } = Astro.props;
---

{variant === 'hero' && (
  <div
    class="pointer-events-none absolute inset-x-0 top-0 z-0 h-240 overflow-hidden"
    aria-hidden="true"
  >
    <div
      class="animate-drift-1 absolute -top-42.5 -left-17.5 h-140 w-140 rounded-full opacity-[0.26] blur-[90px]"
      style="background: radial-gradient(circle, var(--color-accent-vivid), transparent 68%);"
    ></div>
    <div
      class="animate-drift-2 absolute -right-22.5 top-10 h-130 w-130 rounded-full opacity-20 blur-[100px]"
      style="background: radial-gradient(circle, var(--color-violet-brand), transparent 68%);"
    ></div>
    <div
      class="animate-drift-3 absolute left-[36%] top-80 h-120 w-120 rounded-full opacity-[0.18] blur-[100px]"
      style="background: radial-gradient(circle, var(--color-amber-brand), transparent 68%);"
    ></div>
  </div>
)}

{variant === 'compact' && (
  <div
    class="pointer-events-none absolute inset-x-0 top-0 z-0 h-160 overflow-hidden"
    aria-hidden="true"
  >
    <div
      class="animate-drift-1 absolute -top-47.5 -left-15 h-130 w-130 rounded-full opacity-[0.22] blur-[95px]"
      style="background: radial-gradient(circle, var(--color-accent-vivid), transparent 68%);"
    ></div>
    <div
      class="animate-drift-2 absolute -right-22.5 -top-15 h-120 w-120 rounded-full opacity-[0.16] blur-[100px]"
      style="background: radial-gradient(circle, var(--color-violet-brand), transparent 68%);"
    ></div>
  </div>
)}

{variant === 'minimal' && (
  <div
    class="pointer-events-none absolute inset-x-0 top-0 z-0 h-140 overflow-hidden"
    aria-hidden="true"
  >
    <div
      class="animate-drift-1 absolute -top-47.5 -left-15 h-130 w-130 rounded-full opacity-20 blur-[95px]"
      style="background: radial-gradient(circle, var(--color-accent-vivid), transparent 68%);"
    ></div>
    <div
      class="animate-drift-2 absolute -right-22.5 -top-15 h-120 w-120 rounded-full opacity-[0.15] blur-[100px]"
      style="background: radial-gradient(circle, var(--color-violet-brand), transparent 68%);"
    ></div>
  </div>
)}
