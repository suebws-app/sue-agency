---
import StatItem from './ui/StatItem.astro';
---

<section class="relative z-10 mx-auto max-w-310 px-4 pb-5 sm:px-6 md:px-8">
  <div
    class="relative flex min-h-60 items-end overflow-hidden rounded-[22px] border border-dark/10 bg-ink shadow-[0_50px_90px_-50px_rgba(20,18,16,0.55)] sm:aspect-video md:aspect-16/7"
  >
    <div
      class="animate-drift-slow absolute inset-[-18%]"
      style="background:
        radial-gradient(120% 140% at 18% 0%, rgba(255, 82, 51, 0.30), transparent 55%),
        radial-gradient(90% 120% at 92% 20%, rgba(120, 110, 255, 0.22), transparent 50%);"
      aria-hidden="true"
    ></div>
    <div
      class="relative flex w-full flex-wrap items-end justify-between gap-5 px-5 py-6 sm:px-8 sm:py-8 md:px-10 md:py-9.5"
    >
      <div class="min-w-0 flex-1 text-cream">
        <div class="mb-2.5 text-[13px] uppercase tracking-[0.14em] opacity-60">
          Selected build · 2026
        </div>
        <div
          class="font-display text-[clamp(22px,3.4vw,44px)] font-bold leading-tight tracking-[-0.02em] wrap-break-word hyphens-auto"
        >
          Lumen, a headless commerce platform
        </div>
      </div>
      <div class="flex shrink-0 gap-6 text-cream sm:gap-9">
        <StatItem value="0.3s" label="LCP" size="sm" />
        <StatItem value="+41%" label="Conversion" size="sm" />
      </div>
    </div>
  </div>
</section>
