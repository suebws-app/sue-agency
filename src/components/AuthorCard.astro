---
import GradientAvatar from './ui/GradientAvatar.astro';
import PillButton from './ui/PillButton.astro';

interface Props {
  author: string;
  bio: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const { author, bio, ctaHref = '/#contact', ctaLabel = 'Work with us' } = Astro.props;
---

<section class="relative z-10 mx-auto max-w-250 px-8 pt-2 pb-5">
  <div
    class="border-dark/10 bg-card flex flex-wrap items-center gap-5 rounded-[20px] border p-8"
    data-reveal
  >
    <GradientAvatar size={56} />
    <div class="min-w-55 flex-1">
      <div class="font-display text-lg font-bold tracking-[-0.01em]">
        {author}
      </div>
      <p class="text-muted mt-1.5 text-[15px] leading-[1.55]">{bio}</p>
    </div>
    <PillButton href={ctaHref} size="md">{ctaLabel}</PillButton>
  </div>
</section>
