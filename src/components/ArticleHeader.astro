---
import type { PostTag } from '../data/posts';
import GradientAvatar from './ui/GradientAvatar.astro';
import Tag from './ui/Tag.astro';

interface Props {
  tag: PostTag;
  date: string;
  read: string;
  author: string;
  authorRole: string;
  title: string;
  titleAccent?: string;
  description: string;
}

const {
  tag,
  date,
  read,
  author,
  authorRole,
  title,
  titleAccent,
  description,
} = Astro.props;

// Split the title around the accent phrase if one is provided.
let before = title;
let after = '';
if (titleAccent && title.includes(titleAccent)) {
  const idx = title.indexOf(titleAccent);
  before = title.slice(0, idx).trimEnd();
  after = title.slice(idx + titleAccent.length).trimStart();
}
---

<article class="relative z-10 mx-auto max-w-250 px-8 pt-14">
  <a
    href="/journal"
    class="mb-8 inline-flex items-center gap-1.75 text-sm font-semibold text-subtle no-underline hover:text-accent"
  >
    ← Back to Journal
  </a>

  <div class="mb-5.5 flex items-center gap-2">
    <Tag variant="accent">{tag}</Tag>
    <span class="text-[13px] text-subtle">{date} · {read}</span>
  </div>

  <h1
    class="font-display m-0 mb-6 text-[clamp(34px,5.4vw,58px)] font-bold leading-[1.02] tracking-[-0.03em]"
  >
    {titleAccent ? (
      <>
        {before}
        {before && ' '}
        <span class="font-serif italic font-normal text-accent">{titleAccent}</span>
        {after && ' '}
        {after}
      </>
    ) : (
      title
    )}
  </h1>

  <p class="mb-8 text-xl leading-normal text-muted">{description}</p>

  <div
    class="flex items-center gap-3 border-b border-dark/15 pb-9 text-sm text-subtle"
  >
    <GradientAvatar size={40} />
    <div class="flex flex-col">
      <span class="font-semibold text-dark">{author}</span>
      <span>{authorRole}</span>
    </div>
  </div>
</article>
