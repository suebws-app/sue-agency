---
import type { PostTag } from '../data/posts';
import GradientAvatar from './ui/GradientAvatar.astro';
import Tag from './ui/Tag.astro';

interface Props {
  tag: PostTag;
  date: string;
  read: string;
  author: string;
  authorRole: string;
  title: string;
  titleAccent?: string;
  description: string;
}

const { tag, date, read, author, authorRole, title, titleAccent, description } = Astro.props;

// Split the title around the accent phrase if one is provided.
let before = title;
let after = '';
if (titleAccent && title.includes(titleAccent)) {
  const idx = title.indexOf(titleAccent);
  before = title.slice(0, idx).trimEnd();
  after = title.slice(idx + titleAccent.length).trimStart();
}
---

<article class="relative z-10 mx-auto max-w-250 px-8 pt-14" data-reveal-stagger>
  <a
    href="/journal"
    class="text-subtle hover:text-accent mb-8 inline-flex items-center gap-1.75 text-sm font-semibold no-underline"
  >
    ← Back to Journal
  </a>

  <div class="mb-5.5 flex items-center gap-2">
    <Tag variant="accent">{tag}</Tag>
    <span class="text-subtle text-[13px]">{date} · {read}</span>
  </div>

  <h1
    class="font-display m-0 mb-6 text-[clamp(34px,5.4vw,58px)] leading-[1.02] font-bold tracking-[-0.03em]"
  >
    {
      titleAccent ? (
        <>
          {before}
          {before && ' '}
          <span class="text-accent font-serif font-normal italic">{titleAccent}</span>
          {after && ' '}
          {after}
        </>
      ) : (
        title
      )
    }
  </h1>

  <p class="text-muted mb-8 text-xl leading-normal">{description}</p>

  <div class="border-dark/15 text-subtle flex items-center gap-3 border-b pb-9 text-sm">
    <GradientAvatar size={40} />
    <div class="flex flex-col">
      <span class="text-dark font-semibold">{author}</span>
      <span>{authorRole}</span>
    </div>
  </div>
</article>
